# Copy to .env and adjust. Used by docker-compose and the services.

# --- Postgres ---
POSTGRES_USER=philemon
POSTGRES_PASSWORD=philemon
POSTGRES_DB=philemon
# 5433 on the host to avoid clashing with a local/other Postgres on 5432
POSTGRES_PORT=5433
# Connection string the services use:
DATABASE_URL=postgresql://philemon:philemon@localhost:5433/philemon

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=philemon
MINIO_ROOT_PASSWORD=philemon123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=furnishing
# S3 client config for the API:
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=philemon
S3_SECRET_KEY=philemon123
S3_BUCKET=furnishing

# --- Auth (Better Auth) ---
AUTH_SECRET=dev-only-change-me-in-production
AUTH_URL=http://localhost:4000
# Relying-party ID for passkeys (domain, no scheme/port). localhost for dev.
AUTH_RP_ID=localhost
AUTH_RP_NAME=Philemon

# --- Service ports ---
AUTH_PORT=4000
API_PORT=4001
WEB_PORT=5173
# Web app origin (for CORS + passkey origin)
WEB_ORIGIN=http://localhost:5173

# --- Web (Vite) needs these at build time ---
VITE_AUTH_URL=http://localhost:4000
VITE_API_URL=http://localhost:4001
